[debug] [2026-05-19T20:06:08.115Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/endlesstimer-b1f71/rulesets {"name":"projects/endlesstimer-b1f71/rulesets/5e41e271-40aa-40e1-a294-791215c0d44f","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    match /users/{userId} {\n      allow read, update, create: if isOwner(userId);\n      allow delete: if false;\n\n      match /actions/{actionId} {\n        allow read, create, update, delete: if isOwner(userId);\n      }\n\n      match /history_events/{eventId} {\n        allow read, create: if isOwner(userId);\n        allow update: if false;\n        allow delete: if isOwner(userId);\n      }\n    }\n  }\n}\n","name":"firebase/firestore.rules"}]},"createTime":"2026-05-19T20:06:08.152031Z","metadata":{"services":["cloud.firestore"]}}
